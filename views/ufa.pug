extends layout
include mixins

block title
	+title('Unrestricted Free Agents')

block og_meta
	meta(property='og:title' content='Unrestricted Free Agents')
	meta(property='og:description' content='Players entering unrestricted free agency')
	meta(property='og:image' content='https://thedynastyleague.com/images/og/the-gang-slop-og.jpg')

block styles
	link(rel='stylesheet' href='/css/positions.css')

block content
	div.container.py-4
		div.page-header
			h1 Unrestricted Free Agents

		if positionKeys.length === 0
			p.text-muted No unrestricted free agents at this time.
		else
			div.row
				div.col-md-8.col-lg-6.col-xl-4
					+playerTable(playersByPosition, positionKeys)
